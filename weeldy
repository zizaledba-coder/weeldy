    progEl.innerHTML = '<div id="geocode-bar" style="height:100%;background:#4f6ef7;border-radius:3px;width:0%;transition:width 0.3s;"></div>';
    $('map-loading').appendChild(progEl);
  }

  const geocoded = await geocodeBatch(addrs, (done, total) => {
    if(lt) lt.textContent = `Géocodage ${done}/${total}...`;
    const bar = document.getElementById('geocode-bar');
    if(bar) bar.style.width = Math.round(done/total*100)+'%';
  });

  if(lt) lt.textContent = '🔄 Optimisation du trajet...';

  // Étape 3 — Optimisation ORS avec position GPS comme départ
  let ordered = geocoded;
  if(geocoded.length >= 2) {
    try {
      const startLoc = startPos ? [startPos.lng, startPos.lat] : [geocoded[0].lng, geocoded[0].lat];
      const jobs = geocoded.map((g,i) => ({ id:i+1, location:[g.lng,g.lat], service:30 }));
      const body = {
        jobs,
        vehicles: [{ id:1, profile:'driving-car', start:startLoc, end:startLoc }]
      };
      const r = await fetch('https://api.openrouteservice.org/optimization', {
        method:'POST',
        headers:{'Content-Type':'application/json','Authorization':ORS},
        body:JSON.stringify(body)
      });
      const d = await r.json();
      if(d.routes && d.routes[0]) {
