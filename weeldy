// ===== UTILS =====
const $ = id => document.getElementById(id);
function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  $('screen-' + id).classList.add('active');
}
function showLoading(txt) { $('loading-txt').textContent = txt || '...'; $('loading').classList.add('active'); }
function hideLoading() { $('loading').classList.remove('active'); }
function toast(msg, ms = 2500) {
  const t = $('toast'); t.textContent = msg; t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), ms);
}
function addrKey(a) { return (a.numero+'|'+a.rue+'|'+a.cp).toLowerCase().trim(); }
function setDebug(txt) { const d = $('debug-bar'); if(d) d.textContent = txt; }
function setScanStatus(st) {
  const dot = $('status-dot'), txt = $('status-text');
  if (!dot) return;
  dot.className = 'status-dot ' + st;
  const msgs = { scanning: 'Scan automatique — pointez vers l\'adresse', analyzing: 'Analyse en cours...', found: 'Adresse détectée !', idle: 'En attente...' };
  if (txt) txt.textContent = msgs[st] || st;
