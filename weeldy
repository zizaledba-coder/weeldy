// ===== XLSX IMPORT =====
function parseXLSX(data) {
  const wb = XLSX.read(data, { type: 'array' });
  const ws = wb.Sheets[wb.SheetNames[0]];
  const rows = XLSX.utils.sheet_to_json(ws, { header: 1 });
  if (rows.length < 2) return [];
  const h = rows[0].map(c => (c||'').toString().toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').trim());
  const get = (keys) => { for(const k of keys){ const i = h.findIndex(c => keys.some(kk => c.includes(kk))); if(i>=0) return i; } return -1; };
  const iNum = h.findIndex(c => c==='numero' || c==='num' || c==='n°' || c==='no');
  const iRue = h.findIndex(c => c==='rue' || c.includes('street') || c.includes('adresse'));
  const iCp  = h.findIndex(c => c.includes('postal') || c==='cp' || c==='zip');
  const iVil = h.findIndex(c => c==='ville' || c==='city' || c.includes('localit'));
  const iSeq = h.findIndex(c => c==='sequence' || c==='seq' || c==='ordre');
  const iId  = h.findIndex(c => c.includes('tache') || c.includes('id'));
  if (iRue < 0) return [];
  const out = [];
  for (let i = 1; i < rows.length; i++) {
    const r = rows[i]; if (!r || !r[iRue]) continue;
    out.push({
      id: iId>=0 ? (r[iId]||i).toString() : String(i),
      numero: iNum>=0 ? (r[iNum]||'').toString().trim() : '',
      rue: r[iRue].toString().trim(),
      cp: iCp>=0 ? (r[iCp]||'').toString().trim() : '',
      ville: iVil>=0 ? (r[iVil]||'').toString().trim() : '',
      sequence: iSeq>=0 ? (parseInt(r[iSeq])||i) : i,
    });
  }
  return out;
}

function loadAddresses(raw) {
  const total = raw.length;
  const seen = new Map();
  raw.sort((a,b) => a.sequence - b.sequence)
     .forEach(a => { const k = addrKey(a); if (!seen.has(k)) seen.set(k, a); });
  const deduped = Array.from(seen.values());
  S.addresses = deduped;
  $('stat-addr').textContent = deduped.length;
  $('stat-dup').textContent = total - deduped.length;
  $('setup-sub').textContent = `${deduped.length} adresses uniques · ${total-deduped.length} doublons supprimés`;
  showScreen('setup');
}

