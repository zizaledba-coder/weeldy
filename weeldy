<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="mobile-web-app-capable" content="yes">
<title>WEELDY — Tri & Tournée</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<style>
@import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@300;400;500;600&family=JetBrains+Mono:wght@400;700&display=swap');

:root {
  --bg: #080810;
  --bg2: #0d0d1a;
  --surface: #111120;
  --surface2: #181830;
  --border: #1e1e3a;
  --border2: #2a2a50;
  --accent: #00e5ff;
  --accent2: #7b2fff;
  --green: #00ff88;
  --orange: #ff6b00;
  --red: #ff2d55;
  --yellow: #ffe600;
  --text: #e8e8f8;
  --muted: #4a4a7a;
  --dim: #2a2a4a;
  --display: 'Barlow Condensed', sans-serif;
  --body: 'Barlow', sans-serif;
  --mono: 'JetBrains Mono', monospace;
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }

body {
  font-family: var(--body);
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

/* ── SCREENS ── */
.screen { display:none; min-height:100vh; flex-direction:column; }
.screen.active { display:flex; animation: fadeIn 0.2s ease; }
@keyframes fadeIn { from{opacity:0;transform:translateY(4px)} to{opacity:1;transform:translateY(0)} }

/* ── HOME ── */
#screen-home {
  align-items:center; justify-content:center; padding:2rem; gap:1.2rem;
  background:
    radial-gradient(ellipse 80% 60% at 20% 10%, rgba(0,229,255,0.06) 0%, transparent 60%),
    radial-gradient(ellipse 60% 80% at 80% 90%, rgba(123,47,255,0.08) 0%, transparent 60%),
    repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(255,255,255,0.015) 39px, rgba(255,255,255,0.015) 40px),
    repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(255,255,255,0.015) 39px, rgba(255,255,255,0.015) 40px),
    var(--bg);
}
.logo-wrap { text-align:center; margin-bottom:0.5rem; }
.logo-icon {
  width:80px; height:80px; margin:0 auto 1rem;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
  display:flex; align-items:center; justify-content:center; font-size:2rem;
  box-shadow: 0 0 60px rgba(0,229,255,0.25), 0 0 120px rgba(0,229,255,0.1);
  animation: pulse-glow 3s ease-in-out infinite;
}
@keyframes pulse-glow {
  0%,100% { box-shadow: 0 0 40px rgba(0,229,255,0.2), 0 0 80px rgba(0,229,255,0.08); }
  50% { box-shadow: 0 0 80px rgba(0,229,255,0.4), 0 0 160px rgba(0,229,255,0.15); }
}
.logo-title {
  font-family: var(--display);
  font-size: 3.5rem; font-weight:900;
  letter-spacing: 0.15em; text-transform:uppercase;
  background: linear-gradient(90deg, var(--accent), #fff, var(--accent2));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  line-height:1;
}
.logo-sub { font-size:0.75rem; color:var(--muted); letter-spacing:0.2em; text-transform:uppercase; margin-top:0.3rem; }

.home-card {
  width:100%; max-width:380px;
  background: var(--surface);
  border: 1px solid var(--border2);
  border-radius:16px; padding:1.2rem;
  box-shadow: 0 8px 32px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.05);
}
.saved-badge {
  display:inline-flex; align-items:center; gap:0.4rem;
  background: rgba(0,255,136,0.1); border:1px solid rgba(0,255,136,0.3);
  border-radius:6px; padding:0.25rem 0.6rem;
  font-family:var(--mono); font-size:0.65rem; color:var(--green);
  text-transform:uppercase; letter-spacing:0.1em; margin-bottom:0.7rem;
}
.saved-badge::before { content:'●'; animation:blink 1.5s infinite; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }
.saved-info { font-family:var(--display); font-size:1.3rem; font-weight:700; margin-bottom:0.2rem; }
.saved-date { font-size:0.72rem; color:var(--muted); margin-bottom:0.9rem; }

.btn-primary {
  width:100%; padding:0.95rem 1.5rem;
  background: linear-gradient(135deg, var(--accent), rgba(0,229,255,0.7));
  border:none; border-radius:10px; color:#000;
  font-family:var(--display); font-size:1.1rem; font-weight:800;
  letter-spacing:0.08em; text-transform:uppercase; cursor:pointer;
  transition: all 0.15s; position:relative; overflow:hidden;
  box-shadow: 0 4px 20px rgba(0,229,255,0.3);
}
.btn-primary::after { content:''; position:absolute; inset:0; background:linear-gradient(135deg,rgba(255,255,255,0.15),transparent); }
.btn-primary:hover { transform:translateY(-1px); box-shadow:0 6px 30px rgba(0,229,255,0.45); }
.btn-primary:active { transform:translateY(1px); }
.btn-primary.green { background:linear-gradient(135deg,var(--green),rgba(0,255,136,0.7)); box-shadow:0 4px 20px rgba(0,255,136,0.3); }
.btn-primary.green:hover { box-shadow:0 6px 30px rgba(0,255,136,0.45); }

.btn-secondary {
  width:100%; padding:0.75rem;
  background:transparent; border:1px solid var(--border2);
  border-radius:10px; color:var(--muted);
  font-family:var(--body); font-size:0.85rem; cursor:pointer;
  transition:all 0.15s;
}
.btn-secondary:hover { border-color:var(--accent); color:var(--accent); }
.btn-reset {
  width:100%; padding:0.55rem; background:transparent;
  border:1px solid var(--border); border-radius:8px;
  color:var(--dim); font-size:0.75rem; cursor:pointer;
  margin-top:0.4rem; transition:all 0.15s;
}
.btn-reset:hover { border-color:var(--red); color:var(--red); }

/* ── SETUP ── */
#screen-setup { padding:0; }
.screen-header {
  padding:1rem 1.2rem 0.8rem;
  border-bottom:1px solid var(--border);
  background: linear-gradient(180deg, var(--bg2) 0%, transparent 100%);
}
.screen-label { font-family:var(--mono); font-size:0.62rem; color:var(--accent); text-transform:uppercase; letter-spacing:0.15em; margin-bottom:0.2rem; }
.screen-title { font-family:var(--display); font-size:1.6rem; font-weight:800; letter-spacing:0.02em; }
.screen-sub { font-size:0.78rem; color:var(--muted); margin-top:0.2rem; }

.stat-grid { display:grid; grid-template-columns:1fr 1fr; gap:0.8rem; padding:1rem 1.2rem; }
.stat-card {
  background:var(--surface); border:1px solid var(--border2);
  border-radius:12px; padding:0.9rem 1rem;
  position:relative; overflow:hidden;
}
.stat-card::before { content:''; position:absolute; top:0; left:0; right:0; height:2px; background:linear-gradient(90deg,var(--accent),var(--accent2)); }
.stat-val { font-family:var(--display); font-size:2rem; font-weight:900; color:var(--accent); line-height:1; }
.stat-label { font-size:0.68rem; color:var(--muted); margin-top:0.2rem; text-transform:uppercase; letter-spacing:0.08em; }

.section-block { padding:0 1.2rem 1rem; }
.section-label { font-family:var(--mono); font-size:0.62rem; color:var(--muted); text-transform:uppercase; letter-spacing:0.12em; margin-bottom:0.6rem; }
.casier-row {
  display:flex; align-items:center; justify-content:space-between;
  background:var(--surface); border:1px solid var(--border2);
  border-radius:12px; padding:0.9rem 1.1rem;
}
.casier-label-txt { font-family:var(--display); font-size:1rem; font-weight:700; letter-spacing:0.02em; }
.casier-controls { display:flex; align-items:center; gap:0.8rem; }
.counter-btn {
  width:38px; height:38px; border-radius:8px;
  border:1px solid var(--border2); background:var(--surface2);
  color:var(--text); font-size:1.2rem; cursor:pointer; transition:all 0.15s;
}
.counter-btn:hover { background:var(--accent); border-color:var(--accent); color:#000; }
.counter-val { font-family:var(--display); font-size:2rem; font-weight:900; min-width:50px; text-align:center; color:var(--accent); }

.depot-block { padding:0 1.2rem 1rem; }
.depot-row { display:flex; gap:0.5rem; margin-bottom:0.5rem; }
.field-input {
  flex:1; padding:0.65rem 0.8rem;
  background:var(--surface); border:1px solid var(--border2);
  border-radius:8px; color:var(--text); font-family:var(--body);
  font-size:0.88rem; outline:none; transition:border-color 0.15s;
}
.field-input:focus { border-color:var(--accent); }
.field-input.small { width:65px; flex:none; }
.field-hint { font-size:0.68rem; color:var(--muted); margin-top:0.3rem; }

.action-block { padding:0 1.2rem 1.5rem; display:flex; flex-direction:column; gap:0.5rem; }

/* ── TRI ── */
#screen-tri { background:var(--bg); }
.tri-header {
  padding:0.8rem 1.2rem;
  border-bottom:1px solid var(--border);
  display:flex; align-items:center; justify-content:space-between;
  background:var(--bg2);
}
.tri-title { font-family:var(--display); font-size:1.1rem; font-weight:800; letter-spacing:0.05em; text-transform:uppercase; }
.tri-badge {
  font-family:var(--mono); font-size:0.7rem;
  background:rgba(0,229,255,0.1); border:1px solid rgba(0,229,255,0.3);
  color:var(--accent); padding:0.2rem 0.6rem; border-radius:20px;
}

.camera-wrap { position:relative; flex-shrink:0; }
video.cam { width:100%; height:210px; object-fit:cover; background:#000; display:block; }
.scan-overlay { position:absolute; inset:0; pointer-events:none; }
.scan-box {
  position:absolute; top:50%; left:50%;
  transform:translate(-50%,-50%);
  width:90%; height:76px;
  border:2px solid var(--accent);
  border-radius:4px;
  box-shadow: 0 0 0 2000px rgba(0,0,0,0.6), 0 0 20px rgba(0,229,255,0.3);
}
.scan-box::before, .scan-box::after {
  content:''; position:absolute; width:18px; height:18px;
  border-color:var(--accent); border-style:solid;
}
.scan-box::before { top:-2px; left:-2px; border-width:2px 0 0 2px; }
.scan-box::after  { bottom:-2px; right:-2px; border-width:0 2px 2px 0; }
.scan-corner-br { position:absolute; bottom:-2px; left:-2px; width:18px; height:18px; border:2px solid var(--accent); border-width:0 0 2px 2px; }
.scan-corner-tr { position:absolute; top:-2px; right:-2px; width:18px; height:18px; border:2px solid var(--accent); border-width:2px 2px 0 0; }
.scan-line {
  position:absolute; left:4px; right:4px; height:1px;
  background:linear-gradient(90deg, transparent, var(--accent), var(--accent), transparent);
  box-shadow: 0 0 8px var(--accent);
  animation:scanMove 2s ease-in-out infinite; top:0;
}
@keyframes scanMove { 0%,100%{top:4px;opacity:0.8} 50%{top:calc(100% - 5px);opacity:1} }
.scan-hint { position:absolute; bottom:7px; left:0; right:0; text-align:center; font-size:0.65rem; color:rgba(255,255,255,0.5); letter-spacing:0.05em; }

.status-bar {
  display:flex; align-items:center; gap:0.7rem;
  padding:0.55rem 1.2rem;
  background:var(--surface); border-bottom:1px solid var(--border);
  min-height:36px;
}
.status-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }
.status-dot.scanning { background:var(--accent); animation:pulseDot 1.2s infinite; }
.status-dot.analyzing { background:var(--orange); animation:pulseDot 0.5s infinite; }
.status-dot.found { background:var(--green); }
.status-dot.idle { background:var(--muted); }
@keyframes pulseDot { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.4;transform:scale(0.7)} }
.status-txt { font-size:0.75rem; color:var(--muted); flex:1; }

.manual-wrap { padding:0.6rem 1.2rem; display:flex; gap:0.5rem; }
.manual-input {
  flex:1; padding:0.7rem 1rem;
  background:var(--surface); border:1px solid var(--border2);
  border-radius:10px; color:var(--text);
  font-family:var(--body); font-size:0.92rem; outline:none;
  transition:border-color 0.15s;
}
.manual-input:focus { border-color:var(--accent); box-shadow:0 0 0 2px rgba(0,229,255,0.1); }
.manual-btn {
  padding:0.7rem 1rem; background:var(--accent); border:none;
  border-radius:10px; color:#000; cursor:pointer; font-size:1rem;
  font-weight:700; transition:all 0.15s;
}
.manual-btn:hover { background:#33eeff; }

.suggestions {
  margin:0 1.2rem 0.4rem;
  background:var(--surface); border:1px solid var(--border2);
  border-radius:10px; max-height:130px; overflow-y:auto; display:none;
}
.suggestions.open { display:block; }
.sug-item {
  padding:0.6rem 1rem; cursor:pointer; font-size:0.83rem;
  border-bottom:1px solid var(--border); transition:background 0.1s;
  display:flex; align-items:center; gap:0.6rem;
}
.sug-item:last-child { border-bottom:none; }
.sug-item:hover { background:var(--surface2); }
.sug-item::before { content:'→'; color:var(--accent); font-size:0.7rem; }

/* RESULT PANEL */
.result-panel {
  display:none; margin:0.5rem 1.2rem;
  border-radius:12px; padding:1rem 1.2rem;
  animation:slideUp 0.2s ease;
}
@keyframes slideUp { from{transform:translateY(12px);opacity:0} to{transform:translateY(0);opacity:1} }
.result-panel.found {
  display:block;
  background: linear-gradient(135deg, rgba(0,255,136,0.07), rgba(0,229,255,0.04));
  border:1px solid rgba(0,255,136,0.25);
}
.result-lbl { font-family:var(--mono); font-size:0.58rem; color:var(--muted); text-transform:uppercase; letter-spacing:0.15em; margin-bottom:0.2rem; }
.result-casier {
  font-family:var(--display); font-size:4.5rem; font-weight:900;
  color:var(--green); line-height:1;
  text-shadow: 0 0 40px rgba(0,255,136,0.4);
  letter-spacing:-0.02em;
}
.result-addr { font-size:0.85rem; margin-top:0.4rem; color:var(--text); font-weight:500; }

/* ADD PANEL */
.add-panel {
  display:none; margin:0.4rem 1.2rem;
  padding:0.9rem 1rem;
  background:rgba(255,107,0,0.06); border:1px solid rgba(255,107,0,0.25);
  border-radius:12px;
}
.add-title { font-family:var(--mono); font-size:0.62rem; color:var(--orange); text-transform:uppercase; letter-spacing:0.1em; margin-bottom:0.6rem; }
.add-row { display:flex; gap:0.4rem; margin-bottom:0.4rem; }
.add-input {
  flex:1; padding:0.5rem 0.7rem;
  background:var(--surface); border:1px solid var(--border2);
  border-radius:7px; color:var(--text); font-size:0.83rem; outline:none;
}
.add-input.small { width:62px; flex:none; }
.add-btn {
  width:100%; padding:0.6rem;
  background:var(--orange); border:none; border-radius:8px;
  color:#000; font-family:var(--display); font-size:0.95rem; font-weight:800;
  letter-spacing:0.05em; text-transform:uppercase; cursor:pointer;
}

/* DEBUG */
.debug-bar {
  margin:0.3rem 1.2rem; padding:0.35rem 0.7rem;
  background:var(--surface2); border-radius:5px;
  font-family:var(--mono); font-size:0.62rem; color:var(--dim);
}

/* CASIERS GRID */
.casiers-grid {
  padding:0.4rem 1.2rem 0.6rem;
  display:grid; grid-template-columns:repeat(auto-fill,minmax(56px,1fr)); gap:0.35rem;
  max-height:110px; overflow-y:auto;
}
.casier-badge {
  background:var(--surface); border:1px solid var(--border);
  border-radius:6px; padding:0.3rem 0.15rem; text-align:center;
  transition:all 0.15s;
}
.casier-badge.active {
  border-color:var(--accent); background:rgba(0,229,255,0.08);
  box-shadow:0 0 8px rgba(0,229,255,0.15);
}
.casier-badge .cn { font-family:var(--display); font-weight:800; font-size:0.82rem; display:block; color:var(--accent); }
.casier-badge .cc { font-family:var(--mono); color:var(--muted); font-size:0.55rem; }

.done-wrap { padding:0.6rem 1.2rem 1.5rem; }
.cam-btn { padding:0.3rem 0.6rem; background:var(--surface2); border:1px solid var(--border2); border-radius:6px; color:var(--text); cursor:pointer; font-size:0.75rem; transition:all 0.15s; }
.cam-btn:hover { border-color:var(--accent); color:var(--accent); }

/* ── ITINERAIRE ── */
#screen-itineraire { background:var(--bg); }
.itin-header {
  padding:0.8rem 1.2rem; border-bottom:1px solid var(--border);
  display:flex; align-items:center; justify-content:space-between;
  background:var(--bg2);
}
#leaflet-map { height:260px; }
.map-loading {
  height:260px; display:flex; align-items:center; justify-content:center;
  flex-direction:column; gap:0.8rem; background:var(--surface);
}
.gmaps-link {
  display:flex; align-items:center; gap:0.6rem;
  padding:0.7rem 1.2rem; background:var(--surface);
  border-bottom:1px solid var(--border); color:var(--text);
  text-decoration:none; font-size:0.82rem; font-weight:500;
  transition:background 0.15s;
}
.gmaps-link:hover { background:var(--surface2); }
.itin-tabs {
  display:flex; gap:0.4rem; padding:0.6rem 1.2rem;
  border-bottom:1px solid var(--border); background:var(--bg2);
}
.tab-btn {
  flex:1; padding:0.5rem 0.4rem;
  background:var(--surface); border:1px solid var(--border2);
  border-radius:7px; color:var(--muted); font-size:0.75rem;
  font-weight:600; cursor:pointer; transition:all 0.15s;
}
.tab-btn.active { background:var(--accent); border-color:var(--accent); color:#000; }
.tab-btn.green { }
.tab-btn.green.active { background:var(--green); border-color:var(--green); color:#000; }
.itin-list { flex:1; overflow-y:auto; padding:0.6rem 1.2rem 1.5rem; }
.itin-item {
  display:flex; align-items:center; gap:0.8rem;
  padding:0.6rem 0; border-bottom:1px solid var(--border);
}
.itin-num { font-family:var(--mono); font-size:0.72rem; color:var(--muted); min-width:22px; text-align:center; }
.itin-addr { flex:1; font-size:0.83rem; line-height:1.3; }
.itin-addr small { color:var(--muted); font-size:0.68rem; display:block; }
.itin-casier {
  font-family:var(--display); font-size:0.85rem; font-weight:800;
  background:rgba(0,229,255,0.1); color:var(--accent);
  padding:0.2rem 0.5rem; border-radius:5px; border:1px solid rgba(0,229,255,0.2);
}

/* ── BAC ── */
#screen-bac { background:var(--bg); }
.bac-header {
  padding:0.8rem 1.2rem; border-bottom:1px solid var(--border);
  display:flex; align-items:center; justify-content:space-between;
  background:var(--bg2);
}
.bac-stats {
  display:grid; grid-template-columns:1fr 1fr 1fr;
  gap:0.6rem; padding:0.8rem 1.2rem;
  border-bottom:1px solid var(--border);
  background:var(--bg2);
}
.bac-stat {
  background:var(--surface); border:1px solid var(--border2);
  border-radius:9px; padding:0.6rem; text-align:center;
  position:relative; overflow:hidden;
}
.bac-stat::after { content:''; position:absolute; bottom:0; left:0; right:0; height:2px; }
.bac-stat:nth-child(1)::after { background:var(--accent); }
.bac-stat:nth-child(2)::after { background:var(--green); }
.bac-stat:nth-child(3)::after { background:var(--orange); }
.bac-stat .val { font-family:var(--display); font-size:1.4rem; font-weight:900; }
.bac-stat .lbl { font-family:var(--mono); font-size:0.58rem; color:var(--muted); text-transform:uppercase; letter-spacing:0.08em; margin-top:0.1rem; }
.bac-hint {
  padding:0.45rem 1.2rem;
  font-family:var(--mono); font-size:0.6rem; color:var(--muted);
  text-transform:uppercase; letter-spacing:0.1em;
  border-bottom:1px solid var(--border); background:var(--bg2);
}
.bac-list { flex:1; overflow-y:auto; padding:0.6rem 1.2rem 1.5rem; }
.bac-item {
  display:flex; align-items:center; gap:0.8rem;
  padding:0.65rem 0.9rem; margin-bottom:0.4rem;
  border-radius:10px; border:1px solid var(--border2);
  background:var(--surface); position:relative; overflow:hidden;
  transition:all 0.15s;
}
.bac-item::before { content:''; position:absolute; left:0; top:0; bottom:0; width:3px; background:var(--border2); }
.bac-item.first::before { background:var(--green); }
.bac-item.last::before { background:var(--accent); }
.bac-item.first { background:rgba(0,255,136,0.04); border-color:rgba(0,255,136,0.2); }
.bac-item.last { background:rgba(0,229,255,0.04); border-color:rgba(0,229,255,0.2); }
.bac-cnum { font-family:var(--display); font-size:1.6rem; font-weight:900; color:var(--accent); min-width:52px; text-align:center; }
.bac-info { flex:1; }
.bac-rue { font-size:0.82rem; font-weight:600; }
.bac-meta { font-family:var(--mono); font-size:0.62rem; color:var(--muted); margin-top:0.15rem; }
.bac-tag { font-family:var(--mono); font-size:0.62rem; font-weight:700; text-align:right; }

/* ── TOURNEE ── */
#screen-tournee { background:var(--bg); }
.tourn-header {
  padding:0.8rem 1.2rem; border-bottom:1px solid var(--border);
  background:var(--bg2);
}
.tourn-title { font-family:var(--display); font-size:1.1rem; font-weight:800; letter-spacing:0.05em; text-transform:uppercase; }
.tourn-meta { font-family:var(--mono); font-size:0.68rem; color:var(--muted); margin-top:0.15rem; }

.progress-wrap { padding:0.8rem 1.2rem 0.4rem; }
.prog-bar-bg { height:3px; background:var(--border2); border-radius:2px; overflow:hidden; }
.prog-bar-fill {
  height:100%;
  background:linear-gradient(90deg, var(--accent), var(--green));
  border-radius:2px; transition:width 0.4s ease;
  box-shadow: 0 0 8px rgba(0,229,255,0.5);
}
.prog-text { display:flex; justify-content:space-between; font-family:var(--mono); font-size:0.65rem; color:var(--muted); margin-top:0.4rem; }

.current-stop {
  margin:0.8rem 1.2rem;
  background:var(--surface);
  border:1px solid var(--border2);
  border-radius:14px; padding:1.1rem 1.2rem;
  position:relative; overflow:hidden;
}
.current-stop::before { content:''; position:absolute; top:0; left:0; right:0; height:2px; background:linear-gradient(90deg, var(--accent), var(--accent2)); }
.stop-seq { font-family:var(--mono); font-size:0.62rem; color:var(--accent); text-transform:uppercase; letter-spacing:0.12em; margin-bottom:0.4rem; }
.stop-addr { font-family:var(--display); font-size:1.3rem; font-weight:800; line-height:1.25; letter-spacing:0.01em; }
.stop-meta { display:flex; align-items:center; gap:0.5rem; margin-top:0.8rem; flex-wrap:wrap; }
.stop-casier-tag {
  background:var(--accent); color:#000;
  font-family:var(--display); font-size:0.9rem; font-weight:900;
  padding:0.25rem 0.7rem; border-radius:6px; letter-spacing:0.05em;
}
.stop-extra { font-family:var(--mono); font-size:0.68rem; color:var(--muted); }

.gmaps-stop {
  display:flex; align-items:center; gap:0.5rem;
  margin:0.3rem 1.2rem; padding:0.6rem 1rem;
  background:var(--surface); border:1px solid var(--border2);
  border-radius:9px; color:var(--text); text-decoration:none;
  font-size:0.8rem; font-weight:500; transition:all 0.15s;
}
.gmaps-stop:hover { border-color:var(--accent); }

.nav-btns { display:flex; gap:0.6rem; margin:0.5rem 1.2rem; }
.nav-btn {
  flex:1; padding:0.9rem; border-radius:11px; border:none;
  font-family:var(--display); font-weight:800; font-size:1rem;
  letter-spacing:0.05em; text-transform:uppercase; cursor:pointer; transition:all 0.15s;
}
.nav-btn.delivered { background:var(--green); color:#000; box-shadow:0 4px 12px rgba(0,255,136,0.25); }
.nav-btn.absent { background:var(--orange); color:#000; box-shadow:0 4px 12px rgba(255,107,0,0.25); }
.nav-btn.skip { background:var(--surface2); color:var(--muted); border:1px solid var(--border2); }
.nav-btn:hover { transform:translateY(-1px); }
.nav-btn:active { transform:translateY(1px); }

.upcoming { flex:1; overflow-y:auto; padding:0.6rem 1.2rem 1.5rem; }
.upcoming-title { font-family:var(--mono); font-size:0.6rem; color:var(--muted); text-transform:uppercase; letter-spacing:0.12em; margin-bottom:0.5rem; }
.up-item { display:flex; align-items:center; gap:0.7rem; padding:0.5rem 0; border-bottom:1px solid var(--border); font-size:0.82rem; }
.up-item.done { opacity:0.3; }
.up-item.current { color:var(--accent); font-weight:600; }
.up-seq { font-family:var(--mono); font-size:0.65rem; color:var(--muted); min-width:20px; text-align:center; }
.up-casier { font-family:var(--display); font-size:0.78rem; font-weight:800; background:var(--surface2); padding:0.1rem 0.35rem; border-radius:4px; color:var(--accent); }

/* ── COMPLETE ── */
#screen-complete {
  align-items:center; justify-content:center; padding:2rem; text-align:center;
  background:
    radial-gradient(ellipse 60% 50% at 50% 40%, rgba(0,255,136,0.08) 0%, transparent 60%),
    var(--bg);
}
.complete-icon { font-size:4rem; margin-bottom:0.8rem; animation:bounce 1s ease 0.3s both; }
@keyframes bounce { 0%{transform:scale(0)} 60%{transform:scale(1.2)} 100%{transform:scale(1)} }
.complete-title { font-family:var(--display); font-size:2.5rem; font-weight:900; letter-spacing:0.02em; margin-bottom:0.3rem; }
.complete-sub { color:var(--muted); font-size:0.85rem; margin-bottom:2rem; }
.complete-stats { display:grid; grid-template-columns:1fr 1fr 1fr; gap:0.8rem; width:100%; margin-bottom:2rem; }
.comp-stat {
  background:var(--surface); border:1px solid var(--border2);
  border-radius:12px; padding:1rem;
  position:relative; overflow:hidden;
}
.comp-stat::before { content:''; position:absolute; top:0; left:0; right:0; height:2px; }
.comp-stat:nth-child(1)::before { background:var(--green); }
.comp-stat:nth-child(2)::before { background:var(--orange); }
.comp-stat:nth-child(3)::before { background:var(--accent); }
.comp-stat .val { font-family:var(--display); font-size:1.8rem; font-weight:900; }
.comp-stat .lbl { font-family:var(--mono); font-size:0.6rem; color:var(--muted); text-transform:uppercase; letter-spacing:0.08em; margin-top:0.2rem; }

/* ── LOADING ── */
.loading-overlay {
  display:none; position:fixed; inset:0;
  background:rgba(8,8,16,0.9); backdrop-filter:blur(4px);
  z-index:100; align-items:center; justify-content:center; flex-direction:column; gap:1rem;
}
.loading-overlay.active { display:flex; }
.spinner {
  width:36px; height:36px;
  border:2px solid var(--border2); border-top-color:var(--accent);
  border-radius:50%; animation:spin 0.7s linear infinite;
  box-shadow: 0 0 20px rgba(0,229,255,0.2);
}
@keyframes spin { to{transform:rotate(360deg)} }
.loading-txt { font-family:var(--mono); color:var(--muted); font-size:0.8rem; }

/* ── TOAST ── */
.toast {
  position:fixed; bottom:2rem; left:50%;
  transform:translateX(-50%) translateY(100px);
  background:var(--surface2); border:1px solid var(--border2);
  border-radius:10px; padding:0.65rem 1.2rem;
  font-size:0.82rem; z-index:200;
  transition:transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
  white-space:nowrap; max-width:90vw;
  box-shadow: 0 4px 20px rgba(0,0,0,0.5);
}
.toast.show { transform:translateX(-50%) translateY(0); }

/* ── LEAFLET OVERRIDES ── */
.leaflet-container { background:var(--surface); }
.leaflet-popup-content-wrapper { background:var(--surface2); color:var(--text); border:1px solid var(--border2); border-radius:8px; box-shadow:none; }
.leaflet-popup-tip { background:var(--surface2); }
</style>
</head>
