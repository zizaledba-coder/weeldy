function assignCasiers() {
  const sorted = [...S.addresses].sort((a,b) => a.sequence - b.sequence);
  const perC = Math.ceil(sorted.length / S.nbCasiers);
  S.casierMap = {}; S.casierContents = {};
  for(let i=1;i<=S.nbCasiers;i++) S.casierContents[i]=[];
  sorted.forEach((a,i) => {
    const c = Math.min(Math.floor(i/perC)+1, S.nbCasiers);
    S.casierMap[addrKey(a)] = c;
    S.casierContents[c].push(a);
  });
}
