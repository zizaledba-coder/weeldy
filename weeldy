// ===== SEARCH =====
function norm(s) { return s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/[^a-z0-9 ]/g,' ').replace(/\s+/g,' ').trim(); }
function lev(a,b) {
  const m=a.length,n=b.length,dp=Array.from({length:m+1},(_,i)=>[i]);
  for(let j=0;j<=n;j++) dp[0][j]=j;
  for(let i=1;i<=m;i++) for(let j=1;j<=n;j++)
    dp[i][j]=a[i-1]===b[j-1]?dp[i-1][j-1]:1+Math.min(dp[i-1][j],dp[i][j-1],dp[i-1][j-1]);
  return dp[m][n];
}
function findAddress(q) {
  const nq = norm(q);
  return S.addresses.filter(a => {
    const full = norm(a.numero+' '+a.rue+' '+a.cp+' '+a.ville);
    return full.includes(nq) || norm(a.rue).includes(nq);
  }).slice(0,8);
}
function fuzzySearch(q, max=5) {
  if (!q || q.length < 3) return [];
  const nq = norm(q);
  const stopWords = ['monsieur','madame','mr','mme','dr','belgium','belgique','bel','delivery'];
  const cleanQ = nq.split(' ').filter(w => !stopWords.includes(w) && w.length > 1).join(' ');
  return S.addresses.map(a => {
    const full = norm(a.numero+' '+a.rue+' '+a.cp+' '+a.ville);
    const rue = norm(a.rue);
    let score = full.includes(cleanQ) ? 1.0 : 0;
    if (!score) {
      const qw = cleanQ.split(' ').filter(w=>w.length>2);
      const fw = full.split(' ').filter(w=>w.length>2);
      let matched = 0;
      for(const w of qw) for(const fw2 of fw) if(lev(w,fw2)<=Math.floor(Math.max(w.length,fw2.length)*0.3)){matched++;break;}
      score = qw.length ? matched/qw.length : 0;
    }
    return {a, score};
  }).filter(s=>s.score>0.3).sort((a,b)=>b.score-a.score).slice(0,max).map(s=>s.a);
}
function showSuggestions(results) {
  const box = $('suggestions'); box.innerHTML = '';
  results.forEach(a => {
    const item = document.createElement('div'); item.className = 'sug-item';
    item.textContent = `${a.numero} ${a.rue}, ${a.cp} ${a.ville}`;
    item.addEventListener('click', () => { selectAddress(a); box.classList.remove('open'); });
    box.appendChild(item);
  });
  box.classList.toggle('open', results.length > 0);
}

