async function startBarcodeLoop() {
  try {
    if (typeof ZXing === 'undefined') return;
    S.barcodeReader = new ZXing.BrowserMultiFormatReader();
  } catch(e) { return; }
  const video = $('cam-video'), canvas = $('cam-canvas');
  S.scanInterval = setInterval(async () => {
    if (!S.autoScan || !video.videoWidth || S.scanCooldown) return;
    try {
      canvas.width = video.videoWidth; canvas.height = video.videoHeight;
      canvas.getContext('2d').drawImage(video,0,0);
      const imgData = canvas.getContext('2d').getImageData(0,0,canvas.width,canvas.height);
      const res = await S.barcodeReader.decodeFromImageData(imgData);
      if (res && res.getText()) {
        S.scanCooldown = true;
        setScanStatus('found');
        handleBarcode(res.getText());
        setTimeout(() => { S.scanCooldown = false; setScanStatus('scanning'); }, 3000);
      }
    } catch(e) {}
  }, 700);
}
function handleBarcode(text) {
  setDebug('Code: ' + text.slice(0,50));
  $('manual-input').value = text.slice(0,80);
  let found = findAddress(text);
  if (!found.length) found = fuzzySearch(text, 5);
  if (found.length === 1) selectAddress(found[0]);
  else if (found.length > 1) showSuggestions(found);
  else showAddPanel(text);
}

// ===== OCR AUTO LOOP =====
async function startOCRLoop() {
  S.autoScan = true;
  while (S.autoScan) {
    await new Promise(r => setTimeout(r, 2500));
    if (!S.autoScan || S.scanCooldown) continue;
    const video = $('cam-video'), crop = $('crop-canvas');
    if (!video || !video.videoWidth) continue;
    try {
      const scanBox = $('scan-box');
      const fr = scanBox.getBoundingClientRect(), vr = video.getBoundingClientRect();
      const sx = video.videoWidth/vr.width, sy = video.videoHeight/vr.height;
      const cx = Math.max(0,(fr.left-vr.left)*sx), cy = Math.max(0,(fr.top-vr.top)*sy);
      const cw = Math.min(fr.width*sx, video.videoWidth-cx), ch = Math.min(fr.height*sy, video.videoHeight-cy);
      crop.width = cw*3; crop.height = ch*3;
      const ctx = crop.getContext('2d');
      ctx.imageSmoothingEnabled = true; ctx.imageSmoothingQuality = 'high';
      ctx.drawImage(video, cx, cy, cw, ch, 0, 0, crop.width, crop.height);
      // Boost contrast
      const id = ctx.getImageData(0,0,crop.width,crop.height);
      for(let i=0;i<id.data.length;i+=4) for(let c=0;c<3;c++) { let v=id.data[i+c]; id.data[i+c]=Math.min(255,Math.max(0,((v-128)*1.4)+128)); }
      ctx.putImageData(id,0,0);
      setScanStatus('analyzing'); S.scanCooldown = true;
      const { data:{ text, confidence } } = await Tesseract.recognize(crop, 'fra+nld');
      const clean = text.trim().replace(/\n/g,' ').replace(/\s+/g,' ');
      setDebug('OCR('+Math.round(confidence)+'%): '+clean.slice(0,55));
      if (confidence < 25 || clean.length < 4) { S.scanCooldown = false; setScanStatus('scanning'); continue; }
      $('manual-input').value = clean.slice(0,80);
      let found = findAddress(clean);
      if (!found.length) found = fuzzySearch(clean, 5);
      if (found.length === 1) { selectAddress(found[0]); }
      else if (found.length > 1) { showSuggestions(found); toast(found.length+' adresses — choisissez'); setScanStatus('scanning'); }
      else { showAddPanel(clean); setScanStatus('scanning'); }
      setTimeout(() => { S.scanCooldown = false; setScanStatus('scanning'); }, 3000);
    } catch(e) { S.scanCooldown = false; setScanStatus('scanning'); }
  }
}
function stopScan() { S.autoScan = false; if(S.scanInterval){clearInterval(S.scanInterval);S.scanInterval=null;} if(S.stream){S.stream.getTracks().forEach(t=>t.stop());S.stream=null;} }

// ===== OPTIMIZATION =====
const ORS = '5b3ce3597851110001cf6248a93fe6b12c3445fb9e08f3d9ef6a952a';
// Cache geocoding pour éviter doublons
const geocodeCache = {};

// Belgique bounding box
function isInBelgium(lat, lng) {
  return lat >= 49.4 && lat <= 51.6 && lng >= 2.4 && lng <= 6.5;
}

async function geocode(addr) {
  const key = `${addr.numero}|${addr.rue}|${addr.cp}`;
  if (geocodeCache[key]) return geocodeCache[key];

  const ville = addr.ville || 'Bruxelles';
  const cp    = addr.cp    || '1000';
  const num   = addr.numero || '';
  const rue   = addr.rue   || '';

  // Stratégie 1 — Nominatim structured (le plus précis pour adresses belges)
  try {
    const url = `https://nominatim.openstreetmap.org/search?` +
      `street=${encodeURIComponent(num+' '+rue)}` +
      `&city=${encodeURIComponent(ville)}` +
      `&postalcode=${encodeURIComponent(cp)}` +
      `&country=Belgium&format=json&limit=3&addressdetails=1`;
    const r = await fetch(url, { headers: { 'Accept-Language': 'fr', 'User-Agent': 'WEELDY-app/1.0' } });
    const d = await r.json();
    if (d && d.length > 0) {
      for (const item of d) {
        const lat = parseFloat(item.lat), lng = parseFloat(item.lon);
        if (isInBelgium(lat, lng)) {
          geocodeCache[key] = {lat, lng};
          return {lat, lng};
        }
      }
    }
  } catch(e) { console.log('Nominatim error:', e); }

  // Stratégie 2 — Nominatim free text (fallback)
  try {
    const q = encodeURIComponent(`${num} ${rue}, ${cp} ${ville}, Belgique`);
    const url = `https://nominatim.openstreetmap.org/search?q=${q}&format=json&limit=3&countrycodes=be`;
    const r = await fetch(url, { headers: { 'Accept-Language': 'fr', 'User-Agent': 'WEELDY-app/1.0' } });
    const d = await r.json();
    if (d && d.length > 0) {
      for (const item of d) {
        const lat = parseFloat(item.lat), lng = parseFloat(item.lon);
        if (isInBelgium(lat, lng)) {
          geocodeCache[key] = {lat, lng};
          return {lat, lng};
        }
      }
    }
  } catch(e) { console.log('Nominatim fallback error:', e); }

  console.warn('Adresse non géocodée:', num, rue, cp);
  return null;
}

// Géocodage en parallèle par lots
async function geocodeBatch(addrs, onProgress) {
  // Nominatim: max 1 req/sec — traitement séquentiel avec cache
  const results = new Array(addrs.length).fill(null);
  for (let i = 0; i < addrs.length; i++) {
    const key = `${addrs[i].numero}|${addrs[i].rue}|${addrs[i].cp}`;
    const cached = geocodeCache[key];
    results[i] = cached
      ? { addr: addrs[i], ...cached }
      : null;
    if (!cached) {
      const c = await geocode(addrs[i]);
      if (c) results[i] = { addr: addrs[i], ...c };
      await new Promise(r => setTimeout(r, 1100)); // respecte limite Nominatim
    }
    if (onProgress) onProgress(i + 1, addrs.length);
  }
  return results.filter(Boolean);
}

async function getGPSPosition() {
  return new Promise(resolve => {
    if (!navigator.geolocation) { resolve(null); return; }
    navigator.geolocation.getCurrentPosition(
      pos => resolve({ lat: pos.coords.latitude, lng: pos.coords.longitude }),
      () => resolve(null),
      { timeout: 5000, maximumAge: 60000 }
    );
  });
}

async function optimizeAndShow() {
  showScreen('itineraire');
  $('map-loading').style.display = 'flex';
  $('leaflet-map').style.display = 'none';
  // UNIQUEMENT les adresses scannées pendant le tri
  let addrs;
  if (S.scanned.length > 0) {
    // Dédupliquer les adresses scannées
    const seen = new Set();
    addrs = S.scanned
      .map(s => s.address)
      .filter(a => { const k = addrKey(a); if(seen.has(k)) return false; seen.add(k); return true; })
      .sort((a,b) => a.sequence - b.sequence);
    toast(`📦 ${addrs.length} adresses scannées à livrer`);
  } else {
    // Fallback si rien scanné: toutes les adresses
    addrs = [...S.addresses].sort((a,b)=>a.sequence-b.sequence);
    toast('⚠️ Aucun scan — itinéraire sur toutes les adresses');
  }
  const lt = $('map-loading-text');

  // Étape 1 — Position de départ : GPS d'abord, sinon dépôt, sinon première adresse
  if(lt) lt.textContent = '📍 Récupération de votre position GPS...';
  let startPos = null;
  let startLabel = '';

  const gpsPos = await getGPSPosition();
  if (gpsPos) {
    startPos = gpsPos;
    startLabel = 'GPS';
    toast('📍 Départ depuis votre position GPS');
  } else if (S.depot && S.depot.rue) {
    if(lt) lt.textContent = '📍 Géocodage de l'adresse du dépôt...';
    const depotCoords = await geocode(S.depot);
    if (depotCoords) {
      startPos = depotCoords;
      startLabel = 'Dépôt';
      toast('🏭 GPS indisponible — départ depuis le dépôt');
    }
  }
  if (!startPos) toast('⚠️ Départ depuis la première adresse');

  // Étape 2 — Géocodage rapide en parallèle
  if(lt) lt.textContent = 'Géocodage 0/' + addrs.length + '...';

  // Progress bar in loading screen
  let progEl = document.getElementById('geocode-progress');
  if (!progEl) {
    progEl = document.createElement('div');
    progEl.id = 'geocode-progress';
